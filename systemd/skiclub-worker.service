[Unit]
Description=Ski-Club Manager — Laravel Queue Worker
After=network.target mysql.service

[Service]
User=www-data
Group=www-data
WorkingDirectory=/opt/ski-club-manager
ExecStart=/usr/bin/php8.3 artisan queue:work --sleep=3 --tries=3 --max-time=3600
Restart=on-failure
RestartSec=5s

StandardOutput=append:/var/log/skiclub-worker.log
StandardError=append:/var/log/skiclub-worker.log

[Install]
WantedBy=multi-user.target
